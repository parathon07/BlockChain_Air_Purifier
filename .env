# ============================================================
# Blockchain Compliance Layer — Ethereum Configuration
# ============================================================
# This file is read by blockchain_compliance/config.py
# via python-dotenv.
#
# The values below are for a LOCAL Hardhat node.
# Run `npx hardhat node` first, then deploy the contract.
# ============================================================

# Ethereum RPC endpoint (Hardhat local node default)
ETHEREUM_RPC_URL=http://127.0.0.1:8545

# Contract address — filled after running deploy.js
# (will be auto-read from deployment.json by run_ethereum_demo.py)
COMPLIANCE_CONTRACT_ADDRESS=

# Hardhat Account #0 private key (test only — never use in production!)
COMPLIANCE_PRIVATE_KEY=0xac0974bec39a17e36ba4a6b4d238ff944bacb478cbed5efcae784d7bf4f2ff80

# Path to the compiled contract ABI
COMPLIANCE_CONTRACT_ABI_PATH=./blockchain_compliance/contracts/SafetyComplianceAnchor.abi.json

# Batching
BATCH_SIZE=5
